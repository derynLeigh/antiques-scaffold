# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET="replace-me"

# Single-user login. Generate the hash with:
#   npm run auth:hash "your-chosen-password"
AUTH_PASSWORD_HASH="replace-with-bcrypt-hash"

# --- Cloudflare R2 (Phase 2) ---
# Endpoint is https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
# Create a SCOPED R2 API token (Object Read & Write on this bucket only),
# never your main Cloudflare key.
R2_ACCESS_KEY_ID="replace-me"
R2_SECRET_ACCESS_KEY="replace-me"
R2_BUCKET_NAME="antiques-images"
# Public base URL for serving objects (bucket's public r2.dev URL or your
# custom domain). No trailing slash. Requires public access enabled on the bucket.
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# Resend — needed in Phase 7 for buyer enquiry emails. Not used yet.
# AUTH_RESEND_KEY="re_xxxxxxxx"
# AUTH_EMAIL_FROM="enquiries@yourdomain.com"
