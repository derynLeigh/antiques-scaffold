# Neon Postgres connection string (Phase 0)
DATABASE_URL=""

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET="replace-me"

# Magic-link email via Resend (Phase 1)
AUTH_RESEND_KEY="re_xxxxxxxx"
AUTH_EMAIL_FROM="login@yourdomain.com"

# The ONLY email allowed to sign in
ALLOWED_EMAIL="you@example.com"
